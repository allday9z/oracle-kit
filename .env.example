# ============================================================
# oracle-kit — Environment Configuration
# Copy to .env and fill in values
# ============================================================

# ── Ports ────────────────────────────────────────────────────
ORACLE_PORT=47778
STUDIO_PORT=3000
MAW_PORT=3456

# ── Oracle DB ────────────────────────────────────────────────
ORACLE_VECTOR_DB=lancedb
ORACLE_EMBEDDING_PROVIDER=ollama
# Path on HOST where oracle DB is stored (persisted via Docker volume)
ORACLE_DATA_PATH=~/.oracle

# ── Ollama ───────────────────────────────────────────────────
# Use host ollama (recommended for Mac — GPU access)
OLLAMA_URL=http://host.docker.internal:11434
# OR use ollama container (add 'ollama' profile): --profile ollama
# OLLAMA_URL=http://ollama:11434

# ── Oracle Repos (for indexing) ───────────────────────────────
# Path on HOST containing oracle repos to index
# e.g. /Users/yourname/ghq/github.com
GHQ_ROOT=/Users/uficon_dev/ghq/github.com

# Repos to index (space-separated, relative to GHQ_ROOT)
ORACLE_REPOS=allday9z/database-oracle allday9z/conductor-oracle allday9z/m2-manager-oracle

# ── Claude OAuth (for maw fleet) ─────────────────────────────
# Get from: security find-generic-password -s "Claude Code-credentials" -w
CLAUDE_CODE_OAUTH_TOKEN=

# ── GitHub (for auto-dispatch) ────────────────────────────────
GITHUB_PROJECT_OWNER=allday9z
GITHUB_PROJECT_NUMBER=2
